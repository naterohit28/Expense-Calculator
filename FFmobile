/* ── EVENT DETAIL ── */
function showEvDetail(id){
  const ev=D.events.find(e=>e.id===id);if(!ev)return;
  const pays=[...D.cPays.filter(p=>p.evId===id)].sort((a,b)=>new Date(b.date)-new Date(a.date));
  const exps=[...D.expenses.filter(x=>x.evId===id)].sort((a,b)=>new Date(b.date)-new Date(a.date));
  const rec=pays.reduce((s,p)=>s+p.amt,0),exTot=exps.reduce((s,x)=>s+x.amt,0);
  const pend=ev.billing-rec,pct=ev.billing>0?Math.min(100,rec/ev.billing*100):0;
  const profit=ev.billing-exTot;

  // Photos HTML
  const photos=(ev.photos||[]);
