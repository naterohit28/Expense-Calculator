  </div>`;

  document.getElementById('tab-evdetail').innerHTML=`
    <button class="back-btn" onclick="go('events')">← Events</button>
    <div class="d-hdr">
      <div class="d-nm">${ev.name}</div>
      <div class="d-mt">${fmtD(ev.date)} · ${ev.venue} · ${ev.type}${ev.mobile?' · 📞 '+ev.mobile:''}</div>
      <div class="d-stats">
        <div><div class="ds-l">Billing</div><div class="ds-v">${rs(ev.billing)}</div></div>
        <div><div class="ds-l">Received</div><div class="ds-v">${rs(rec)}</div></div>
        <div><div class="ds-l">Pending</div><div class="ds-v">${rs(Math.max(0,pend))}</div></div>
      </div>
      <div style="height:5px;background:rgba(255,255,255,.2);border-radius:3px;margin-top:12px;overflow:hidden"><div style="height:100%;width:${pct}%;background:#fff;border-radius:3px;transition:width .4s"></div></div>
    </div>

    <!-- P&L MINI -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px">
      <div class="card-sm" style="padding:12px;text-align:center"><div class="lbl ca">Expenses</div><div class="n-md ca" style="margin-top:4px">${rs(exTot)}</div></div>
      <div class="card-sm" style="padding:12px;text-align:center"><div class="lbl" style="color:${profit>=0?'var(--green)':'var(--red)'}">Profit</div><div class="n-md" style="margin-top:4px;color:${profit>=0?'var(--green)':'var(--red)'}">${rs(profit)}</div></div>
      <div class="card-sm" style="padding:12px;text-align:center"><div class="lbl">Margin</div><div class="n-md" style="margin-top:4px;color:${profit>=0?'var(--green)':'var(--red)'}">
        ${ev.billing>0?Math.round(profit/ev.billing*100)+'%':'—'}</div></div>
    </div>

    ${ev.notes?`<div class="card-sm" style="padding:12px 14px;margin-bottom:16px"><div class="lbl" style="margin-bottom:4px">Notes</div><div style="font-size:13px;line-height:1.5">${ev.notes}</div></div>`:''}

    <!-- PHOTOS -->
    <div class="sec">Photos</div>
    <div class="card-sm" style="padding:12px 14px;margin-bottom:16px">${photoHtml}</div>

    <!-- CLIENT PAYMENTS -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin:18px 0 10px">
      <div class="sec" style="margin:0">Client Payments</div>
      <button style="background:var(--accent);color:#fff;border:none;border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer" onclick="openCPayModal('${ev.id}')">+ Add</button>
    </div>
    <div class="card" style="padding:0 16px;margin-bottom:16px">
      ${pays.map(p=>`<div class="pay-row">
        <div><div class="n-sm">${rs(p.amt)}</div><div class="b-sm">${fmtD(p.date)} · ${p.mode||'Cash'}${p.notes?' · '+p.notes:''}</div></div>
        <button class="del-btn" onclick="delRow('cPays','${p.id}','evdetail','${ev.id}')">×</button>
      </div>`).join('')||'<div style="padding:14px 0;text-align:center" class="b-sm">No payments yet</div>'}
    </div>

    <!-- EXPENSES -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin:18px 0 10px">
      <div class="sec" style="margin:0">Event Expenses</div>
      <button style="background:var(--red);color:#fff;border:none;border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer" onclick="openExpModal('${ev.id}')">+ Add</button>
