    <div class="card" style="padding:0 16px;margin-bottom:16px">
      ${exps.map(x=>{const ven=D.vendors.find(v=>v.id===x.venId);return`<div class="row-item">
        <div class="row-ico" style="background:rgba(220,38,38,.08)">${CI[x.cat]||'💸'}</div>
