/* ── VENDOR DETAIL ── */
function showVenDetail(id){
  const vn=D.vendors.find(v=>v.id===id);if(!vn)return;
  const exps=D.expenses.filter(x=>x.venId===id);
  const pays=D.vPays.filter(p=>p.venId===id);
  const te=exps.reduce((s,x)=>s+x.amt,0),tp=pays.reduce((s,p)=>s+p.amt,0),bal=te-tp;
  document.getElementById('tab-vendetail').innerHTML=`
    <button class="back-btn" onclick="go('vendors')">← Vendors</button>
    <div class="card" style="padding:18px;margin-bottom:16px">
      <div class="n-md" style="margin-bottom:3px">${vn.name}</div>
      <div class="b-sm" style="margin-bottom:14px">${vn.cat}${vn.phone?' · 📞 '+vn.phone:''}${vn.notes?' · '+vn.notes:''}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;text-align:center">
        <div><div class="lbl ca">Credit</div><div class="n-md ca" style="margin-top:4px">${rs(te)}</div></div>
        <div><div class="lbl cg">Paid</div><div class="n-md cg" style="margin-top:4px">${rs(tp)}</div></div>
        <div><div class="lbl">Balance</div><div class="n-md" style="margin-top:4px;color:${bal>0?'var(--red)':'var(--green)'}">${rs(bal)}</div></div>
      </div>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <div class="sec" style="margin:0">Vendor Payments</div>
      <button style="background:var(--accent);color:#fff;border:none;border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer" onclick="openVPayModal('${vn.id}')">+ Add</button>
    </div>
    <div class="card" style="padding:0 16px;margin-bottom:16px">
      ${pays.map(p=>{const ev=D.events.find(e=>e.id===p.evId);return`<div class="pay-row">
        <div><div class="n-sm">${rs(p.amt)}</div><div class="b-sm">${fmtD(p.date)} · ${p.mode}${ev?' · '+ev.name:''}</div></div>
        <button class="del-btn" onclick="delRow('vPays','${p.id}','vendetail','${vn.id}')">×</button>
      </div>`;}).join('')||'<div style="padding:14px 0;text-align:center" class="b-sm">No payments made yet</div>'}
    </div>
    <div class="sec">Expenses Assigned</div>
    <div class="card" style="padding:0 16px;margin-bottom:16px">
      ${exps.map(x=>{const ev=D.events.find(e=>e.id===x.evId);return`<div class="row-item">
        <div class="row-ico" style="background:rgba(220,38,38,.08)">${CI[x.cat]||'💸'}</div>
        <div class="row-body"><div class="row-nm">${x.head}</div><div class="row-mt">${fmtD(x.date)}${ev?' · '+ev.name:''}</div></div>
        <div class="n-sm cr">${rs(x.amt)}</div>
      </div>`;}).join('')||'<div style="padding:14px 0;text-align:center" class="b-sm">No expenses assigned</div>'}
    </div>
    <button class="btn btn-ol" onclick="openVenModal('${vn.id}')">✏ Edit Vendor</button>
  `;
  document.getElementById('tab-vendetail').dataset.vnid=id;
  go('vendetail');
}

/* ── SUMMARY / REPORTS ── */
function rSummary(){
  const totalBill=D.events.reduce((s,e)=>s+e.billing,0);
  const totalExp=D.expenses.reduce((s,x)=>s+x.amt,0);
  const totalRec=D.cPays.reduce((s,p)=>s+p.amt,0);
  const profit=totalBill-totalExp;

  // Expense by category
  const byCat={};
  D.expenses.forEach(x=>{ byCat[x.cat]=(byCat[x.cat]||0)+x.amt; });
  const maxCat=Math.max(...Object.values(byCat),1);
  const catBars=Object.entries(byCat).sort((a,b)=>b[1]-a[1]).map(([cat,amt])=>`
    <div class="bar-row">
      <div class="bar-label">${cat}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${amt/maxCat*100}%;background:var(--red)"></div></div>
      <div class="bar-val cr">${rs(amt)}</div>
    </div>`).join('')||'<div class="b-sm" style="text-align:center;padding:16px">No data</div>';

  // P&L per event
  const evPL=D.events.map(ev=>{
    const rec=evRec(ev.id),exp=evExp(ev.id),pl=ev.billing-exp,pct=ev.billing>0?Math.max(0,Math.min(100,pl/ev.billing*100)):0;
    return{ev,rec,exp,pl,pct};
  }).sort((a,b)=>b.pl-a.pl);

  const plRows=evPL.map(r=>`
    <div class="bar-row" style="align-items:center;gap:10px;margin-bottom:12px" onclick="showEvDetail('${r.ev.id}')">
      <div style="width:110px;flex-shrink:0">
        <div style="font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${r.ev.name}</div>
        <div class="b-sm">${fmtD(r.ev.date)}</div>
      </div>
      <div style="flex:1">
        <div class="bar-track"><div class="bar-fill" style="width:${r.pct}%;background:${r.pl>=0?'var(--green)':'var(--red)'}"></div></div>
      </div>
      <div style="width:72px;text-align:right;flex-shrink:0;font-size:12px;font-weight:700;color:${r.pl>=0?'var(--green)':'var(--red)'}">${rs(r.pl)}</div>
    </div>`).join('')||'<div class="b-sm" style="text-align:center;padding:16px">No events</div>';

  // Payment mode breakdown
  const byMode={};
  D.cPays.forEach(p=>{ byMode[p.mode]=(byMode[p.mode]||0)+p.amt; });
  const modeColors={Cash:'#D97706',UPI:'#2563EB',NEFT:'#16A34A',Cheque:'#EA580C',Bank:'#7c3aed'};
  const modeRows=Object.entries(byMode).sort((a,b)=>b[1]-a[1]).map(([m,a])=>`
    <div class="bar-row">
      <div class="bar-label">${m}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${a/Math.max(...Object.values(byMode),1)*100}%;background:${modeColors[m]||'var(--blue)'}"></div></div>
      <div class="bar-val cg">${rs(a)}</div>
    </div>`).join('')||'<div class="b-sm" style="text-align:center;padding:16px">No data</div>';

  document.getElementById('summary-content').innerHTML=`
    <!-- KPIs -->
    <div class="stat-grid" style="margin-bottom:16px">
      <div class="sc"><div class="lbl">Events</div><div class="n-lg" style="margin-top:4px">${D.events.length}</div></div>
      <div class="sc"><div class="lbl cg">Net Profit</div><div class="n-lg cg" style="margin-top:4px">${rs(profit)}</div></div>
      <div class="sc"><div class="lbl">Margin</div><div class="n-lg" style="margin-top:4px;color:${totalBill>0?(profit>=0?'var(--green)':'var(--red)'):'var(--muted)'}">
        ${totalBill>0?Math.round(profit/totalBill*100)+'%':'—'}</div></div>
      <div class="sc"><div class="lbl">Vendors</div><div class="n-lg" style="margin-top:4px">${D.vendors.length}</div></div>
    </div>

    <!-- P&L Per Event -->
    <div class="chart-card">
      <div class="chart-title">📅 Profit / Loss Per Event</div>
      ${plRows}
    </div>

    <!-- Expense By Category -->
    <div class="chart-card">
      <div class="chart-title">💸 Expenses by Category</div>
      ${catBars}
    </div>

    <!-- Payment Mode -->
    <div class="chart-card">
      <div class="chart-title">💳 Collections by Payment Mode</div>
      ${modeRows}
    </div>

    <!-- Event Leaderboard -->
    <div class="chart-card">
      <div class="chart-title">🏆 Event Leaderboard (by Billing)</div>
      ${[...D.events].sort((a,b)=>b.billing-a.billing).map((e,i)=>`
        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)">
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:24px;height:24px;border-radius:6px;background:${i===0?'var(--amber)':i===1?'var(--muted)':i===2?'var(--accent)':'var(--card2)'};display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:${i<3?'#fff':'var(--muted)'}">${i+1}</div>
            <div><div style="font-size:13px;font-weight:600">${e.name}</div><div class="b-sm">${fmtD(e.date)} · ${e.venue}</div></div>
          </div>
          <div class="n-md co">${rs(e.billing)}</div>
        </div>`).join('')||'<div class="b-sm" style="text-align:center;padding:16px">No events</div>'}
    </div>
  `;
}

/* ── MODAL OPENERS ── */
function openEvModal(id){
  const ev=id?D.events.find(e=>e.id===id):null;
  document.getElementById('ev-id').value=ev?ev.id:'';
  document.getElementById('ev-name').value=ev?ev.name:'';
  document.getElementById('ev-date').value=ev?ev.date:'';
  document.getElementById('ev-type').value=ev?ev.type:'Wedding';
  document.getElementById('ev-venue').value=ev?ev.venue:'';
  document.getElementById('ev-billing').value=ev?ev.billing:'';
  document.getElementById('ev-mobile').value=ev?ev.mobile:'';
  document.getElementById('ev-notes').value=ev?ev.notes||'':'';
  document.getElementById('ev-mtitle').textContent=ev?'Edit Event':'New Event';
  document.getElementById('ev-modal').classList.add('active');
}

function openExpModal(fixEvId){
  const ex=typeof fixEvId==='object'&&fixEvId?fixEvId:null;
  const preEvId=typeof fixEvId==='string'?fixEvId:null;
  document.getElementById('exp-id').value=ex?ex.id:'';
  document.getElementById('exp-ev').innerHTML=D.events.map(e=>`<option value="${e.id}">${e.name} – ${fmtD(e.date)}</option>`).join('');
  if(preEvId) document.getElementById('exp-ev').value=preEvId;
  else if(ex) document.getElementById('exp-ev').value=ex.evId;
  document.getElementById('exp-cat').innerHTML=Object.keys(HEADS).map(c=>`<option>${c}</option>`).join('');
  if(ex) document.getElementById('exp-cat').value=ex.cat;
  loadHeads();
  if(ex) document.getElementById('exp-head').value=ex.head;
  document.getElementById('exp-amt').value=ex?ex.amt:'';
  document.getElementById('exp-date').value=ex?ex.date:today();
  document.getElementById('exp-mode').value=ex?ex.mode:'Cash';
  document.getElementById('exp-notes').value=ex?ex.notes:'';
  document.getElementById('exp-vendor').innerHTML=`<option value="">None</option>`+D.vendors.map(v=>`<option value="${v.id}">${v.name}</option>`).join('');
  if(ex&&ex.venId) document.getElementById('exp-vendor').value=ex.venId;
  document.getElementById('exp-mtitle').textContent=ex?'Edit Expense':'Record Expense';
  document.getElementById('exp-modal').classList.add('active');
}

