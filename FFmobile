<!DOCTYPE html>
<html lang="en" class="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Flavor Fusion</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
<style>
/* ── TOKENS ── */
html.dark  { --bg:#0F172A; --bg2:#0a1120; --card:#1E293B; --card2:#253347; --border:#334155; --text:#F1F5F9; --muted:#94A3B8; --hover:#2a3f58; }
html.light { --bg:#F8FAFC; --bg2:#eef2f7; --card:#FFFFFF; --card2:#f1f5f9; --border:#E2E8F0; --text:#0F172A; --muted:#64748B; --hover:#f1f5f9; }
:root { --accent:#EA580C; --green:#16A34A; --red:#DC2626; --amber:#D97706; --blue:#2563EB; --nav-h:64px; --hdr-h:56px; }

/* ── BASE ── */
*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent; }
html { height:100%; }
body { font-family:'Inter',sans-serif; font-size:14px; background:var(--bg); color:var(--text); min-height:100%; overflow-y:auto; overflow-x:hidden; -webkit-font-smoothing:antialiased; -webkit-overflow-scrolling:touch; }
::-webkit-scrollbar { display:none; } * { scrollbar-width:none; }

/* ── TYPOGRAPHY ── */
.lbl  { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--muted); }
.n-xl { font-size:26px; font-weight:900; line-height:1; }
.n-lg { font-size:20px; font-weight:700; line-height:1.1; }
.n-md { font-size:16px; font-weight:700; }
.n-sm { font-size:14px; font-weight:600; }
.b-sm { font-size:11px; color:var(--muted); font-weight:500; }
.cg { color:var(--green); } .cr { color:var(--red); } .ca { color:var(--amber); } .cb { color:var(--blue); } .co { color:var(--accent); }

/* ── LAYOUT ── */
.hdr { position:fixed; top:0; left:0; right:0; height:var(--hdr-h); background:var(--bg); border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; padding:0 16px; z-index:100; }
.logo { font-size:15px; font-weight:700; color:var(--accent); }
.logo-sub { font-size:10px; color:var(--muted); font-weight:600; margin-left:6px; }
.hdr-right { display:flex; gap:8px; }
.icon-btn { width:34px; height:34px; border-radius:8px; border:1px solid var(--border); background:var(--card); display:flex; align-items:center; justify-content:center; font-size:15px; cursor:pointer; }
.icon-btn:active { opacity:.6; }

.bot-nav { position:fixed; bottom:0; left:0; right:0; height:var(--nav-h); background:var(--card); border-top:1px solid var(--border); display:flex; z-index:100; padding-bottom:env(safe-area-inset-bottom); }
.nav-it { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:3px; cursor:pointer; color:var(--muted); font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.05em; transition:color .15s; position:relative; }
.nav-it.active { color:var(--accent); }
.nav-it::after { content:''; position:absolute; bottom:0; left:50%; transform:translateX(-50%) scaleX(0); width:18px; height:2px; background:var(--accent); border-radius:1px; transition:transform .2s; }
.nav-it.active::after { transform:translateX(-50%) scaleX(1); }
.nav-ic { font-size:18px; }

.main { padding-top:calc(var(--hdr-h) + 20px); padding-left:16px; padding-right:16px; padding-bottom:calc(var(--nav-h) + 80px); }
.tab { display:none; } .tab.active { display:block; }

.fab { position:fixed; right:18px; bottom:calc(var(--nav-h)+14px); width:50px; height:50px; border-radius:14px; background:var(--accent); border:none; color:#fff; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center; box-shadow:0 6px 20px rgba(234,88,12,.4); z-index:90; transition:transform .12s; }
.fab:active { transform:scale(.91); }

/* ── CARDS ── */
.card { background:var(--card); border:1px solid var(--border); border-radius:16px; }
.card-sm { background:var(--card); border:1px solid var(--border); border-radius:12px; }

/* ── STAT GRID ── */
.stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:16px; }
.sc { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:14px 16px; }
.sc.full { grid-column:1/-1; }
.sc.acc { background:var(--accent); border-color:transparent; }
.sc.acc .lbl,.sc.acc .n-lg { color:#fff; }

/* ── SECTION HEADER ── */
.sec { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--muted); margin:18px 0 10px; }

/* ── BADGES ── */
.badge { display:inline-block; font-size:10px; font-weight:600; padding:2px 8px; border-radius:20px; text-transform:uppercase; letter-spacing:.04em; }
.b-paid    { background:rgba(22,163,74,.12); color:var(--green); }
.b-partial { background:rgba(215,119,6,.12); color:var(--amber); }
.b-pending { background:rgba(220,38,38,.1); color:var(--red); }
.b-blue    { background:rgba(37,99,235,.1); color:var(--blue); }

/* ── PROGRESS ── */
.prog { height:4px; background:var(--border); border-radius:2px; overflow:hidden; margin-top:10px; }
.prog-fill { height:100%; background:var(--green); border-radius:2px; transition:width .4s; }

/* ── EVENT CARD ── */
.ev-card { background:var(--card); border:1px solid var(--border); border-left:3px solid var(--accent); border-radius:14px; padding:14px; margin-bottom:10px; cursor:pointer; transition:opacity .15s; }
.ev-card:active { opacity:.75; }

/* ── ROW ITEMS ── */
.row-item { display:flex; align-items:center; gap:12px; padding:13px 0; border-bottom:1px solid var(--border); }
.row-item:last-child { border-bottom:none; }
.row-ico { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; }
.row-body { flex:1; min-width:0; }
.row-nm { font-size:13px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.row-mt { font-size:11px; color:var(--muted); margin-top:1px; }

/* ── QUICK ACTIONS ── */
.qa-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:16px; }
.qa { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:14px 12px; cursor:pointer; text-align:center; transition:opacity .15s; }
.qa:active { opacity:.7; }
.qa-ic { font-size:20px; margin-bottom:6px; }
.qa-lb { font-size:12px; font-weight:600; color:var(--text); }
.qa.qa-p { background:var(--accent); border-color:var(--accent); }
.qa.qa-p .qa-lb { color:#fff; }
.qa.qa-r { background:rgba(220,38,38,.08); border-color:rgba(220,38,38,.18); }
.qa.qa-r .qa-lb { color:var(--red); }

/* ── OVERDUE ROW ── */
.od-row { display:flex; justify-content:space-between; align-items:center; padding:12px 14px; background:var(--card); border:1px solid var(--border); border-radius:12px; margin-bottom:8px; cursor:pointer; }
.od-row:active { opacity:.7; }

/* ── MODAL SHEET ── */
.modal-ov { display:none; position:fixed; inset:0; background:rgba(0,0,0,.55); z-index:200; backdrop-filter:blur(4px); align-items:flex-end; }
.modal-ov.active { display:flex; }
.sheet { background:var(--card); width:100%; border-radius:20px 20px 0 0; padding:16px 20px calc(24px + env(safe-area-inset-bottom)); max-height:92dvh; overflow-y:auto; animation:sUp .22s ease; }
@keyframes sUp { from{transform:translateY(32px);opacity:0}to{transform:translateY(0);opacity:1} }
.s-handle { width:32px; height:4px; background:var(--border); border-radius:2px; margin:0 auto 18px; }
.s-title { font-size:17px; font-weight:700; margin-bottom:18px; }

/* ── FORM ── */
.field { margin-bottom:14px; }
.field label { display:block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--muted); margin-bottom:6px; }
.field input,.field select,.field textarea { width:100%; background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:11px 13px; color:var(--text); font-family:'Inter',sans-serif; font-size:14px; font-weight:500; outline:none; transition:border-color .15s; appearance:none; }
html.light .field input,html.light .field select,html.light .field textarea { background:#F8FAFC; }
.field input:focus,.field select:focus,.field textarea:focus { border-color:var(--accent); }
.field textarea { resize:vertical; min-height:72px; }
.f2 { display:grid; grid-template-columns:1fr 1fr; gap:10px; }

/* ── BUTTONS ── */
.btn { width:100%; padding:13px; border-radius:12px; border:none; font-family:'Inter',sans-serif; font-size:14px; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px; margin-top:6px; transition:opacity .15s; }
.btn:active { opacity:.75; }
.btn-o { background:var(--accent); color:#fff; }
.btn-r { background:var(--red); color:#fff; }
.btn-g { background:transparent; border:1px solid var(--border); color:var(--muted); }
.btn-ol { background:transparent; border:1px solid var(--border); color:var(--text); }
.del-btn { width:26px; height:26px; border-radius:6px; border:1px solid var(--border); background:transparent; color:var(--muted); cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0; }
.del-btn:active { background:rgba(220,38,38,.12); color:var(--red); }
.back-btn { display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:600; color:var(--accent); background:none; border:none; cursor:pointer; padding:0; margin-bottom:14px; }

/* ── DETAIL HEADER ── */
.d-hdr { background:var(--accent); border-radius:16px; padding:18px; margin-bottom:16px; color:#fff; }
.d-nm  { font-size:20px; font-weight:700; margin-bottom:3px; }
.d-mt  { font-size:12px; opacity:.8; margin-bottom:14px; }
.d-stats { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; }
.ds-l  { font-size:9px; font-weight:700; opacity:.72; text-transform:uppercase; letter-spacing:.08em; margin-bottom:2px; }
.ds-v  { font-size:16px; font-weight:700; }

/* ── PHOTO ── */
.photo-strip { display:flex; gap:10px; overflow-x:auto; padding:4px 0 8px; }
.photo-thumb { width:80px; height:80px; border-radius:10px; object-fit:cover; flex-shrink:0; cursor:pointer; border:2px solid transparent; transition:border-color .15s; }
.photo-thumb:hover { border-color:var(--accent); }
.photo-add { width:80px; height:80px; border-radius:10px; border:1.5px dashed var(--border); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px; cursor:pointer; flex-shrink:0; color:var(--muted); font-size:10px; font-weight:600; }
.photo-add:active { background:var(--hover); }
#photo-input { display:none; }

/* ── CHARTS ── */
canvas { display:block; }
.chart-wrap { position:relative; width:100%; }

/* ── TOAST ── */
#toast { position:fixed; top:calc(var(--hdr-h)+10px); left:50%; transform:translateX(-50%); background:var(--card); border:1px solid var(--border); color:var(--text); padding:9px 18px; border-radius:40px; font-size:13px; font-weight:600; z-index:300; display:none; white-space:nowrap; box-shadow:0 4px 16px rgba(0,0,0,.25); }

/* ── DRAWER ── */
.drawer { position:fixed; inset:0; z-index:150; display:none; }
.drawer.active { display:block; }
.drawer-bg { position:absolute; inset:0; background:rgba(0,0,0,.45); }
.drawer-panel { position:absolute; left:0; top:0; bottom:0; width:228px; background:var(--card); border-right:1px solid var(--border); padding:48px 14px 24px; display:flex; flex-direction:column; }
.d-logo { font-size:15px; font-weight:700; color:var(--accent); margin-bottom:2px; }
.d-sub  { font-size:10px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.08em; margin-bottom:24px; }
.d-item { display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:10px; margin-bottom:2px; cursor:pointer; font-size:13px; font-weight:600; color:var(--muted); transition:all .15s; }
.d-item.active { background:rgba(234,88,12,.1); color:var(--accent); }

/* ── SUMMARY TAB ── */
.chart-card { background:var(--card); border:1px solid var(--border); border-radius:16px; padding:16px; margin-bottom:14px; }
.chart-title { font-size:13px; font-weight:700; margin-bottom:14px; }
.bar-row { display:flex; align-items:center; gap:10px; margin-bottom:8px; }
.bar-label { font-size:11px; font-weight:600; color:var(--muted); width:90px; flex-shrink:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.bar-track { flex:1; height:8px; background:var(--border); border-radius:4px; overflow:hidden; }
.bar-fill { height:100%; border-radius:4px; transition:width .6s ease; }
.bar-val { font-size:11px; font-weight:700; width:70px; text-align:right; flex-shrink:0; }

/* ── PAY ROW ── */
.pay-row { display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--border); }
.pay-row:last-child { border-bottom:none; }

/* ── EMPTY ── */
.empty { text-align:center; padding:40px 20px; }
.empty-ic { font-size:36px; margin-bottom:10px; }
.empty-tx { font-size:13px; font-weight:500; color:var(--muted); }

/* ── VENDOR CARD ── */
.ven-card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:14px 16px; margin-bottom:10px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; }
.ven-card:active { opacity:.75; }
</style>
</head>
<body>
<div id="toast"></div>

<!-- HEADER -->
<header class="hdr">
  <div><span class="logo">🍽 Flavor Fusion</span><span class="logo-sub">v5</span></div>
  <div class="hdr-right">
    <div class="icon-btn" id="theme-btn" onclick="toggleTheme()">🌙</div>
    <div class="icon-btn" onclick="toggleDrawer()">☰</div>
  </div>
</header>

<!-- DRAWER -->
<div class="drawer" id="drawer">
  <div class="drawer-bg" onclick="toggleDrawer()"></div>
  <div class="drawer-panel">
    <div class="d-logo">Flavor Fusion</div>
    <div class="d-sub">Business App v5</div>
    <div class="d-item active" id="d-home"     onclick="go('home');toggleDrawer()">📊 Dashboard</div>
    <div class="d-item" id="d-events"   onclick="go('events');toggleDrawer()">📅 Events</div>
    <div class="d-item" id="d-expenses" onclick="go('expenses');toggleDrawer()">💸 Expenses</div>
    <div class="d-item" id="d-vendors"  onclick="go('vendors');toggleDrawer()">🤝 Vendors</div>
    <div class="d-item" id="d-summary"  onclick="go('summary');toggleDrawer()">📈 Reports</div>
    <div style="margin-top:auto;display:flex;flex-direction:column;gap:8px;padding:0 2px">
      <button onclick="exportData();toggleDrawer()" style="width:100%;padding:10px 12px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text);font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px;">⬇ Export Data</button>
      <button onclick="document.getElementById('import-input').click();toggleDrawer()" style="width:100%;padding:10px 12px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text);font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px;">⬆ Import Data</button>
      <span class="lbl" style="padding:4px 12px 0">Private · Local Only</span>
    </div>
  </div>
</div>
<input type="file" id="import-input" accept=".json" style="display:none">

<!-- MAIN -->
<main class="main">

  <!-- HOME / DASHBOARD -->
  <div id="tab-home" class="tab active">
    <div class="stat-grid" id="kpi"></div>
    <div class="sec">Quick Actions</div>
    <div class="qa-grid">
      <div class="qa qa-p" onclick="go('events');openEvModal()"><div class="qa-ic">📅</div><div class="qa-lb">New Event</div></div>
      <div class="qa qa-r" onclick="go('expenses');openExpModal()"><div class="qa-ic">💸</div><div class="qa-lb">Add Expense</div></div>
      <div class="qa" onclick="go('events')"><div class="qa-ic">📋</div><div class="qa-lb">All Events</div></div>
      <div class="qa" onclick="go('vendors');openVenModal()"><div class="qa-ic">🤝</div><div class="qa-lb">Add Vendor</div></div>
    </div>
    <div class="sec">Overdue Collections</div>
    <div id="od-list"></div>
  </div>

  <!-- EVENTS -->
  <div id="tab-events" class="tab">
    <div class="sec" style="margin-top:0">Event Portfolio</div>
    <div id="ev-list"></div>
  </div>

  <!-- EVENT DETAIL -->
  <div id="tab-evdetail" class="tab"></div>

  <!-- EXPENSES -->
  <div id="tab-expenses" class="tab">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px">
      <div class="card" style="padding:14px"><div class="lbl">Entries</div><div class="n-lg" style="margin-top:4px" id="exp-ct">0</div></div>
      <div class="card" style="padding:14px"><div class="lbl cr">Total Out</div><div class="n-lg cr" style="margin-top:4px" id="exp-tot">₹0</div></div>
    </div>
    <div class="card" style="padding:0 16px" id="exp-list"></div>
  </div>

  <!-- VENDORS -->
  <div id="tab-vendors" class="tab">
    <div class="sec" style="margin-top:0">Vendor Directory</div>
    <div id="ven-list"></div>
  </div>

  <!-- VENDOR DETAIL -->
  <div id="tab-vendetail" class="tab"></div>

  <!-- SUMMARY / REPORTS -->
  <div id="tab-summary" class="tab">
    <div class="sec" style="margin-top:0">Business Reports</div>
    <div id="summary-content"></div>
  </div>

</main>

<button class="fab" id="fab" onclick="fabAct()">+</button>

<!-- BOTTOM NAV -->
<nav class="bot-nav">
  <div class="nav-it active" id="n-home"     onclick="go('home')"><div class="nav-ic">📊</div><span>Home</span></div>
  <div class="nav-it" id="n-events"   onclick="go('events')"><div class="nav-ic">📅</div><span>Events</span></div>
  <div class="nav-it" id="n-expenses" onclick="go('expenses')"><div class="nav-ic">💸</div><span>Expenses</span></div>
  <div class="nav-it" id="n-vendors"  onclick="go('vendors')"><div class="nav-ic">🤝</div><span>Vendors</span></div>
  <div class="nav-it" id="n-summary"  onclick="go('summary')"><div class="nav-ic">📈</div><span>Reports</span></div>
</nav>

<!-- ══════════ MODALS ══════════ -->

<!-- EVENT MODAL -->
<div class="modal-ov" id="ev-modal">
  <div class="sheet">
    <div class="s-handle"></div>
    <div class="s-title" id="ev-mtitle">New Event</div>
    <input type="hidden" id="ev-id">
    <div class="field"><label>Client / Event Name *</label><input type="text" id="ev-name" placeholder="e.g. Sharma Wedding"></div>
    <div class="f2">
      <div class="field"><label>Date *</label><input type="date" id="ev-date"></div>
      <div class="field"><label>Type</label>
        <select id="ev-type"><option>Wedding</option><option>Reception</option><option>Haldi</option><option>Birthday</option><option>Corporate</option><option>Other</option></select>
      </div>
    </div>
    <div class="field"><label>Venue *</label><input type="text" id="ev-venue" placeholder="Hall / Location"></div>
    <div class="f2">
      <div class="field"><label>Total Billing (₹) *</label><input type="number" id="ev-billing" placeholder="0"></div>
      <div class="field"><label>Client Mobile</label><input type="tel" id="ev-mobile" placeholder="9XXXXXXXXX"></div>
    </div>
    <div class="field"><label>Notes</label><textarea id="ev-notes" placeholder="Any notes about this event..."></textarea></div>
    <button class="btn btn-o" onclick="saveEvent()">Save Event</button>
    <button class="btn btn-g" onclick="closeModals()">Cancel</button>
  </div>
</div>

<!-- EXPENSE MODAL -->
<div class="modal-ov" id="exp-modal">
  <div class="sheet">
    <div class="s-handle"></div>
    <div class="s-title" id="exp-mtitle">Record Expense</div>
    <input type="hidden" id="exp-id">
    <div class="field"><label>Event *</label><select id="exp-ev"></select></div>
    <div class="f2">
      <div class="field"><label>Category</label><select id="exp-cat" onchange="loadHeads()"></select></div>
      <div class="field"><label>Expense Head *</label><select id="exp-head"></select></div>
    </div>
    <div class="f2">
      <div class="field"><label>Amount (₹) *</label><input type="number" id="exp-amt" placeholder="0"></div>
      <div class="field"><label>Date *</label><input type="date" id="exp-date"></div>
    </div>
    <div class="f2">
      <div class="field"><label>Payment Mode</label>
        <select id="exp-mode"><option>Cash</option><option>UPI</option><option>NEFT</option><option>Cheque</option></select>
      </div>
      <div class="field"><label>Vendor</label><select id="exp-vendor"></select></div>
    </div>
    <div class="field"><label>Notes</label><input type="text" id="exp-notes" placeholder="Details / Remarks"></div>
    <button class="btn btn-r" onclick="saveExp()">Record Expense</button>
    <button class="btn btn-g" onclick="closeModals()">Cancel</button>
  </div>
</div>

<!-- CLIENT PAYMENT MODAL -->
<div class="modal-ov" id="cpay-modal">
  <div class="sheet">
    <div class="s-handle"></div>
    <div class="s-title">Add Client Payment</div>
    <input type="hidden" id="cpay-evid">
    <input type="hidden" id="cpay-id">
    <div class="field"><label>Amount (₹) *</label><input type="number" id="cpay-amt" placeholder="0"></div>
    <div class="f2">
      <div class="field"><label>Date *</label><input type="date" id="cpay-date"></div>
      <div class="field"><label>Mode</label>
