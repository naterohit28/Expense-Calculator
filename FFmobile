function loadHeads(){
  const cat=document.getElementById('exp-cat').value;
  document.getElementById('exp-head').innerHTML=(HEADS[cat]||[]).map(h=>`<option>${h}</option>`).join('');
}

/* ── SAVERS ── */
function saveEvent(){
  const nm=document.getElementById('ev-name').value.trim(),dt=document.getElementById('ev-date').value,vn=document.getElementById('ev-venue').value.trim(),bl=parseFloat(document.getElementById('ev-billing').value);
  if(!nm||!dt||!vn||!bl){toast('Fill required fields');return;}
  const id=document.getElementById('ev-id').value;
  const existing=D.events.find(e=>e.id===id);
  const d={id:id||uid('EV'),name:nm,date:dt,type:document.getElementById('ev-type').value,venue:vn,billing:bl,mobile:document.getElementById('ev-mobile').value,notes:document.getElementById('ev-notes').value,photos:existing?existing.photos||[]:[]};
  if(id) D.events=D.events.map(e=>e.id===id?d:e);
  else D.events.push(d);
  save();closeModals();toast('Event saved');render(CT);
}

function saveExp(){
  const am=parseFloat(document.getElementById('exp-amt').value),dt=document.getElementById('exp-date').value;
  if(!am||!dt){toast('Fill required fields');return;}
  const id=document.getElementById('exp-id').value;
  const d={id:id||uid('EX'),evId:document.getElementById('exp-ev').value,cat:document.getElementById('exp-cat').value,head:document.getElementById('exp-head').value,amt:am,date:dt,mode:document.getElementById('exp-mode').value,notes:document.getElementById('exp-notes').value,venId:document.getElementById('exp-vendor').value};
  if(id) D.expenses=D.expenses.map(x=>x.id===id?d:x);
  else D.expenses.push(d);
  save();closeModals();toast('Expense recorded');
  if(CT==='evdetail'){const eid=document.getElementById('tab-evdetail').dataset.evid;if(eid){showEvDetail(eid);return;}}
  render(CT);
}

function saveCPay(){
  const am=parseFloat(document.getElementById('cpay-amt').value),dt=document.getElementById('cpay-date').value;
  if(!am||!dt){toast('Fill required fields');return;}
  const id=document.getElementById('cpay-id').value;
  const evId=document.getElementById('cpay-evid').value;
  const d={id:id||uid('CP'),evId,amt:am,date:dt,mode:document.getElementById('cpay-mode').value,notes:document.getElementById('cpay-notes').value};
  if(id) D.cPays=D.cPays.map(p=>p.id===id?d:p);
  else D.cPays.push(d);
  save();closeModals();toast('Payment added');
  if(CT==='evdetail'){const eid=document.getElementById('tab-evdetail').dataset.evid;if(eid){showEvDetail(eid);return;}}
  render(CT);
}

function saveVen(){
  const nm=document.getElementById('ven-name').value.trim();
  if(!nm){toast('Enter vendor name');return;}
  const id=document.getElementById('ven-id').value;
  const d={id:id||uid('VN'),name:nm,cat:document.getElementById('ven-cat').value,phone:document.getElementById('ven-phone').value,notes:document.getElementById('ven-notes').value};
  if(id) D.vendors=D.vendors.map(v=>v.id===id?d:v);
  else D.vendors.push(d);
  save();closeModals();toast('Vendor saved');render(CT);
}

function saveVPay(){
  const am=parseFloat(document.getElementById('vpay-amt').value),dt=document.getElementById('vpay-date').value;
  if(!am||!dt){toast('Fill required fields');return;}
  const id=document.getElementById('vpay-id').value;
  const venId=document.getElementById('vpay-venid').value;
  const d={id:id||uid('VP'),venId,evId:document.getElementById('vpay-ev').value,amt:am,date:dt,mode:document.getElementById('vpay-mode').value,notes:document.getElementById('vpay-notes').value};
  if(id) D.vPays=D.vPays.map(p=>p.id===id?d:p);
  else D.vPays.push(d);
  save();closeModals();toast('Vendor payment saved');
  if(CT==='vendetail'){const vid=document.getElementById('tab-vendetail').dataset.vnid;if(vid){showVenDetail(vid);return;}}
  render(CT);
}

/* ── DELETE ── */
function delRow(type,id,refreshView,detailId){
  if(!confirm('Delete this record?'))return;
  D[type]=D[type].filter(x=>x.id!==id);
  save();toast('Deleted');
  if(refreshView==='evdetail'&&detailId){showEvDetail(detailId);return;}
  if(refreshView==='vendetail'&&detailId){showVenDetail(detailId);return;}
  render(CT);
}

/* ── PHOTOS ── */
function triggerPhoto(evId){
  pendingPhotoEvId=evId;
  document.getElementById('photo-input').click();
}
document.getElementById('photo-input').addEventListener('change',function(){
  const files=Array.from(this.files);if(!files.length||!pendingPhotoEvId)return;
  const ev=D.events.find(e=>e.id===pendingPhotoEvId);if(!ev)return;
  if(!ev.photos)ev.photos=[];
  let loaded=0;
  files.forEach(file=>{
    const reader=new FileReader();
    reader.onload=e=>{
      ev.photos.push(e.target.result);
      loaded++;
      if(loaded===files.length){save();toast('Photo added');showEvDetail(pendingPhotoEvId);}
    };
    reader.readAsDataURL(file);
  });
  this.value='';
});

function openLightbox(evId,idx){
  const ev=D.events.find(e=>e.id===evId);
  if(!ev||!ev.photos||!ev.photos[idx])return;
  document.getElementById('lb-img').src=ev.photos[idx];
  document.getElementById('lightbox').style.display='flex';
}
function closeLightbox(){ document.getElementById('lightbox').style.display='none'; }

/* ── EXPORT / IMPORT ── */
function exportData(){
  const payload = {
    version: 'ffv5',
    exportedAt: new Date().toISOString(),
    events:   D.events,
    cPays:    D.cPays,
    expenses: D.expenses,
    vendors:  D.vendors,
    vPays:    D.vPays
  };
  const json = JSON.stringify(payload, null, 2);
  const blob = new Blob([json], {type:'application/json'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  const date = new Date().toISOString().split('T')[0];
  a.href     = url;
  a.download = `flavor-fusion-backup-${date}.json`;
  a.click();
  URL.revokeObjectURL(url);
  toast('Data exported ✓');
}

document.getElementById('import-input').addEventListener('change', function(){
  const file = this.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const payload = JSON.parse(e.target.result);
      // Validate it's our format
      if(!payload.version || payload.version !== 'ffv5' || !Array.isArray(payload.events)){
        toast('Invalid backup file'); return;
      }
      if(!confirm(`Import will REPLACE all current data with:\n• ${payload.events.length} events\n• ${payload.expenses.length} expenses\n• ${payload.cPays.length} payments\n• ${payload.vendors.length} vendors\n\nContinue?`)) return;
      D.events   = payload.events   || [];
      D.cPays    = payload.cPays    || [];
      D.expenses = payload.expenses || [];
      D.vendors  = payload.vendors  || [];
      D.vPays    = payload.vPays    || [];
      save();
      go('home');
      toast('Data imported ✓');
    } catch(err){
      toast('Failed to read file');
    }
  };
  reader.readAsText(file);
  this.value = '';
});

/* ── BOOT ── */
rHome();
