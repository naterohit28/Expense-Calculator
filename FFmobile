      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-top:12px">
        <div><div class="lbl">Pending</div><div class="n-md ca">${rs(Math.max(0,pend))}</div></div>
        <div style="text-align:right"><div class="b-sm">Billing: ${rs(ev.billing)}</div><div style="font-size:11px;font-weight:600;color:var(--green);margin-top:1px">Rcvd: ${rs(rec)}</div></div>
      </div>
      <div class="prog"><div class="prog-fill" style="width:${pct}%"></div></div>
